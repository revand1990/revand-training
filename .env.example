# Kopieer dit bestand naar .env en vul je Strato-gegevens in.
# Het .env bestand wordt NIET naar GitHub gepusht (staat in .gitignore).

# Vind deze gegevens in je Strato-controlepaneel
SFTP_HOST=ssh.strato.nl
SFTP_USER=jouwdomein.nl        # je volledige domeinnaam
SFTP_PATH=/                    # pad op de server, meestal / of /htdocs/
